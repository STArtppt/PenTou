{
  "name": "pentou",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "Local-first AI conversation manager — pin, organize, and excerpt chats from ChatGPT / DeepSeek / Claude into native Markdown.",
  "license": "MIT",
  "author": "STArtppt",
  "homepage": "https://github.com/STArtppt/pentou",
  "repository": {
    "type": "git",
    "url": "https://github.com/STArtppt/pentou.git"
  },
  "bugs": {
    "url": "https://github.com/STArtppt/pentou/issues"
  },
  "keywords": [
    "ai",
    "chatgpt",
    "deepseek",
    "claude",
    "conversation",
    "markdown",
    "local-first",
    "react",
    "vite"
  ],
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "build:all": "pnpm build && pnpm build:server",
    "start": "node dist-server/src/server/index.js",
    "dev": "vite",
    "postinstall": "node scripts/download-obscura.cjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "cheerio": "^1.2.0",
    "clsx": "2.1.1",
    "date-fns": "3.6.0",
    "formidable": "^3.5.1",
    "lucide-react": "0.487.0",
    "motion": "12.23.24",
    "react-dnd": "16.0.1",
    "react-dnd-html5-backend": "16.0.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sonner": "2.0.3",
    "tw-animate-css": "1.3.8"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.1.12",
    "@types/formidable": "^3.4.5",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-react": "4.7.0",
    "tailwindcss": "4.1.12",
    "typescript": "^6.0.3",
    "vite": "6.3.5",
    "vite-plugin-compression": "^0.5.1",
    "vitest": "^1.6.0"
  },
  "peerDependencies": {
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "pnpm": {
    "overrides": {
      "vite": "6.3.5"
    }
  }
}
